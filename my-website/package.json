{
  "name": "my-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs",
    "start": "yarn docusaurus start",
    "build": "yarn docusaurus build",
    "swizzle": "yarn docusaurus swizzle",
    "deploy": "yarn docusaurus deploy",
    "clear": "yarn docusaurus clear",
    "serve": "yarn docusaurus serve",
    "write-translations": "yarn docusaurus write-translations",
    "write-heading-ids": "yarn docusaurus write-heading-ids",
    "typecheck": "tsc",
    "verify": "yarn typecheck && yarn build",
    "generate:weekly-outlook": "node scripts/generate-weekly-outlook.cjs",
    "deploy:auto": "node scripts/deploy-github.cjs",
    "weekly:local": "yarn generate:weekly-outlook && yarn verify",
    "weekly:publish": "yarn generate:weekly-outlook && yarn verify && yarn deploy:auto"
  },
  "dependencies": {
    "@docusaurus/core": "3.7.0",
    "@docusaurus/preset-classic": "3.7.0",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "markmap-lib": "^0.18.11",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-bootstrap": "^2.9.1",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.7.0",
    "@docusaurus/tsconfig": "3.7.0",
    "@docusaurus/types": "3.7.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
